# =========================================================
# LOCAL DEVELOPMENT — copy to .env, never commit .env
# =========================================================
DEBUG=True
SECRET_KEY=django-insecure-replace-this-locally
ALLOWED_HOSTS=localhost,127.0.0.1

# Local SQLite (dev only)
DATABASE_URL=sqlite:///db.sqlite3

# Email (console backend used in dev by default)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tridavimpex@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Company Info
COMPANY_NAME=TriDAV Impex
COMPANY_EMAIL=tridavimpex@gmail.com
COMPANY_PHONE=+91-8979399684
COMPANY_ADDRESS=Baghpat, Uttar Pradesh, India
WHATSAPP_NUMBER=918979399684

# Google Analytics (optional)
GA_TRACKING_ID=

# =========================================================
# PRODUCTION (Railway) — set these in Railway dashboard
# =========================================================
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<long random string>
# DATABASE_URL=<auto-set by Railway PostgreSQL plugin>
# ALLOWED_HOSTS=yourdomain.up.railway.app,tridavimpex.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.up.railway.app,https://tridavimpex.com
# EMAIL_HOST_PASSWORD=<gmail app password>
#
# --- Cloudflare R2 (for media uploads) ---
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=tridav-media
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_DOMAIN=pub-<hash>.r2.dev

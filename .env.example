# =========================================================
# LOCAL DEVELOPMENT — copy to .env, never commit .env
# =========================================================
DEBUG=True
SECRET_KEY=django-insecure-replace-this-locally
ALLOWED_HOSTS=localhost,127.0.0.1

# Local SQLite (dev only)
DATABASE_URL=sqlite:///db.sqlite3

# Email (console backend used in dev by default)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tridavimpex@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Company Info
COMPANY_NAME=TriDAV Impex
COMPANY_EMAIL=tridavimpex@gmail.com
COMPANY_PHONE=+91-8979399684
COMPANY_ADDRESS=Baghpat, Uttar Pradesh, India
WHATSAPP_NUMBER=918979399684

# Google Analytics (optional)
GA_TRACKING_ID=

# =========================================================
# PRODUCTION (Render + Neon) — set these in the Render dashboard,
# not in a committed file. See SETUP.md for the full free-tier
# deployment walkthrough (Render web service + Neon Postgres +
# optional Cloudflare R2 for persistent media uploads).
# =========================================================
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<auto-generated by render.yaml>
# DATABASE_URL=<Neon connection string — neon.tech free tier, never expires>
# ALLOWED_HOSTS=yourapp.onrender.com,tridavimpex.com
# CSRF_TRUSTED_ORIGINS=https://yourapp.onrender.com,https://tridavimpex.com
# EMAIL_HOST_PASSWORD=<gmail app password>
#
# --- Cloudflare R2 (optional — persists /admin/ image uploads across
#     restarts; without it, only git-committed seed images survive) ---
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=tridav-media
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_DOMAIN=pub-<hash>.r2.dev
